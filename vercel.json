{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "includeFiles": "node_modules/mysql2/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/backend/server.js"
    }
  ]
}
